{
  "name": "gestion-gasolina",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Vehículos y Combustible",
  "main": "./out/main/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "node tests/unit/costoCalculator.standalone.test.js && node tests/unit/weekCalculator.standalone.test.js && node tests/unit/databaseChofers.test.js && node tests/unit/databaseVehiculos.test.js && node tests/unit/databaseSalidas.test.js && node tests/unit/ggwService.test.js && node tests/unit/excelService.test.js",
    "test:watch": "nodemon --exec 'npm test'",
    "test:coverage": "node tests/unit/costoCalculator.standalone.test.js --coverage && node tests/unit/weekCalculator.standalone.test.js --coverage && node tests/unit/databaseChofers.test.js --coverage && node tests/unit/databaseVehiculos.test.js --coverage && node tests/unit/databaseSalidas.test.js --coverage && node tests/unit/ggwService.test.js --coverage && node tests/unit/excelService.test.js --coverage",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "rebuild:win": "electron-rebuild -f -w better-sqlite3 -m . --arch x64",
    "rebuild:mac": "electron-rebuild -f -w better-sqlite3 -m . --arch x64",
    "rebuild:mac:arm": "electron-rebuild -f -w better-sqlite3 -m . --arch arm64",
    "build:win": "npm run build && npm run rebuild:win && electron-builder --win --config",
    "build:mac": "npm run build && npm run rebuild:mac && electron-builder --mac --config",
    "build:mac:arm": "npm run build && npm run rebuild:mac:arm && electron-builder --mac --config",
    "build:linux": "npm run build && electron-builder --linux --config",
    "build:all": "npm run build:win && npm run build:mac && npm run build:linux",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "electron-log": "^5.2.4",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.gestiongasolina.app",
    "productName": "Gestion Gasolina",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Gestion Gasolina"
    },
    "publish": null
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/out/",
      "/dist/",
      "/build/"
    ],
    "verbose": true,
    "bail": false,
    "transform": {},
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/main/**/*.js",
      "!src/main/main.js",
      "!src/main/preload.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "clearMocks": true,
    "restoreMocks": true
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
